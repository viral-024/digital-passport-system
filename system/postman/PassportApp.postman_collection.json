{
  "info": {
    "_postman_id": "7f7bb957-7f1a-4d40-bc62-2ec9c6f2ab11",
    "name": "PassportApp API",
    "description": "Postman collection for PassportApp. This app uses HTTP Basic authentication for protected routes, not JWT/Bearer tokens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "{{authEmail}}",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{authPassword}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "auth": {
        "type": "noauth"
      },
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"citizen1\",\n  \"password\": \"password123\",\n  \"email\": \"citizen1@example.com\",\n  \"role\": \"CITIZEN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Body required.\n\nAllowed role values: CITIZEN, OFFICER, ADMIN"
          },
          "response": []
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"citizen1@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Body required.\n\nThis endpoint returns user details only. The app uses HTTP Basic auth on protected routes, so keep using email/password in the environment."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Create Application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"fullName\": \"Virat Kohli\",\n  \"dob\": \"1988-11-05\",\n  \"address\": \"Mumbai, India\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/applications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "applications"
              ]
            },
            "description": "Body required.\n\nFor CITIZEN users, userId is ignored and the authenticated user is used. For ADMIN, userId is used."
          },
          "response": []
        },
        {
          "name": "Get All Applications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/applications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "applications"
              ]
            },
            "description": "No body."
          },
          "response": []
        },
        {
          "name": "Get Application By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/applications/{{applicationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "applications",
                "{{applicationId}}"
              ]
            },
            "description": "No body."
          },
          "response": []
        },
        {
          "name": "Update Application",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Virat Kohli\",\n  \"dob\": \"1988-11-05\",\n  \"address\": \"Updated Address, Mumbai\",\n  \"status\": \"PENDING\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/applications/{{applicationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "applications",
                "{{applicationId}}"
              ]
            },
            "description": "Body required."
          },
          "response": []
        },
        {
          "name": "Delete Application",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/applications/{{applicationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "applications",
                "{{applicationId}}"
              ]
            },
            "description": "No body."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Add Document",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documentType\": \"AADHAR\",\n  \"filePath\": \"/uploads/aadhar-card.pdf\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/documents?appId={{applicationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents"
              ],
              "query": [
                {
                  "key": "appId",
                  "value": "{{applicationId}}"
                }
              ]
            },
            "description": "Body required.\n\nAllowed documentType values: AADHAR, PAN, PHOTO, ADDRESS_PROOF"
          },
          "response": []
        },
        {
          "name": "Get Documents By Application",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/documents/application/{{applicationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "application",
                "{{applicationId}}"
              ]
            },
            "description": "No body."
          },
          "response": []
        },
        {
          "name": "Delete Document",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/documents/{{documentId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "{{documentId}}"
              ]
            },
            "description": "No body."
          },
          "response": []
        },
        {
          "name": "Check Documents Complete",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/documents/check-complete/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "check-complete",
                "{{userId}}"
              ]
            },
            "description": "No body."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Appointments",
      "item": [
        {
          "name": "Create Appointment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentDate\": \"2026-04-10\",\n  \"timeSlot\": \"10:00 AM - 11:00 AM\",\n  \"status\": \"SCHEDULED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/appointments?appId={{applicationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointments"
              ],
              "query": [
                {
                  "key": "appId",
                  "value": "{{applicationId}}"
                }
              ]
            },
            "description": "Body required.\n\nAllowed status values: SCHEDULED, COMPLETED, CANCELLED. If omitted, the server defaults to SCHEDULED on create."
          },
          "response": []
        },
        {
          "name": "Get All Appointments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/appointments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointments"
              ]
            },
            "description": "No body."
          },
          "response": []
        },
        {
          "name": "Update Appointment",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentDate\": \"2026-04-12\",\n  \"timeSlot\": \"11:00 AM - 12:00 PM\",\n  \"status\": \"COMPLETED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "appointments",
                "{{appointmentId}}"
              ]
            },
            "description": "Body required."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Verifications",
      "item": [
        {
          "name": "Create Verification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"VERIFIED\",\n  \"remarks\": \"All documents are valid\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/verifications?appId={{applicationId}}&officerId={{officerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "verifications"
              ],
              "query": [
                {
                  "key": "appId",
                  "value": "{{applicationId}}"
                },
                {
                  "key": "officerId",
                  "value": "{{officerId}}"
                }
              ]
            },
            "description": "Body required.\n\nAllowed status values: VERIFIED, REJECTED.\n\nIf the authenticated user is OFFICER, officerId is effectively ignored and the current officer is used. ADMIN can assign officerId."
          },
          "response": []
        },
        {
          "name": "Get All Verifications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/verifications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "verifications"
              ]
            },
            "description": "No body."
          },
          "response": []
        },
        {
          "name": "Get Verification By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/verifications/{{verificationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "verifications",
                "{{verificationId}}"
              ]
            },
            "description": "No body."
          },
          "response": []
        },
        {
          "name": "Update Verification",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"REJECTED\",\n  \"remarks\": \"Document mismatch found\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/verifications/{{verificationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "verifications",
                "{{verificationId}}"
              ]
            },
            "description": "Body required."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ]
}
